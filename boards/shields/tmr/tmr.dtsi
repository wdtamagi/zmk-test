#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/analog-stick/modes.h>
#include <dt-bindings/zmk/keys.h>
#include <physical_layouts.dtsi>

&adc {
    status = "okay";

    #address-cells = <1>;
    #size-cells = <0>;
    channel@0 {
        reg = <0>;
        zephyr,input-positive = <NRF_SAADC_AIN0>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };
    channel@1 {
        reg = <1>;
        zephyr,input-positive = <NRF_SAADC_AIN5>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };
    channel@7 {
        reg = <7>;
        zephyr,input-positive = <NRF_SAADC_AIN7>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };
};

/ {
    chosen {
        zmk,kscan = &kscan;
        zmk,physical-layout = &physical_layout0;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan>;
        transform = <&default_transform>;
        keys
            = <&key_physical_attrs 100 100 0 0 0 0 0>
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <1>;
        rows = <1>;
        map = <RC(0,0)>;
    };

    /* Minimal kscan — ZMK requires one even when all input comes from analog sticks.
       Using kscan-mock with no events so it never fires. */
    kscan: kscan0 {
        compatible = "zmk,kscan-mock";
        columns = <1>;
        rows = <1>;
        events = <0>;
    };

    /* Stick 0: PS5 dual-axis hall-effect joystick (X=AIN0, Y=AIN5) */
    analog_stick0: analog_stick_0 {
        compatible = "zmk,analog-stick";
        io-channels = <&adc 0>, <&adc 1>;
        x-min = <0>;
        x-center = <1877>;
        x-max = <3750>;
        y-min = <0>;
        y-center = <1877>;
        y-max = <3750>;
        deadzone-percent = <5>;
        wait-period-idle = <100>;
        wait-period-active = <8>;
        /* Biquad IIR filter coefficients (b0, b1, b2, a0, a1, a2) — carried over from HE config */
        filter-coefficients = <0x3ca485df 0x3d2485df 0x3ca485df 0x3f800000 0xbfc7cf71 0x3f242f9d>;
    };

    /* Stick 1: Single-axis trigger on AIN7 (P0.31) */
    analog_stick1: analog_stick_1 {
        compatible = "zmk,analog-stick";
        io-channels = <&adc 7>;
        x-min = <0>;
        x-center = <1877>;
        x-max = <3750>;
        deadzone-percent = <5>;
        wait-period-idle = <100>;
        wait-period-active = <8>;
    };

    /* Listener for stick 0 — layer-aware mode switching */
    analog_stick_listener0: analog_stick_listener_0 {
        compatible = "zmk,analog-stick-listener";
        device = <&analog_stick0>;

        layer0 {
            layers = <0>;
            mode = <ANALOG_STICK_MODE_SWITCH>;
            up-keycode = <UP>;
            down-keycode = <DOWN>;
            left-keycode = <LEFT>;
            right-keycode = <RIGHT>;
            switch-activation-point = <40>;
            switch-hysteresis = <4>;
        };
        layer1 {
            layers = <1>;
            mode = <ANALOG_STICK_MODE_MOUSE>;
            mouse-min-speed = <1>;
            mouse-max-speed = <15>;
        };
    };

    /* Listener for stick 1 — switch mode on all layers.
       NOTE: The analog stick switch mode emits raw HID keycodes via
       zmk_hid_keyboard_press(), NOT ZMK behaviors. This means &mo, &lt,
       and other ZMK behaviors cannot be used here. Both directions are
       bound to regular keys. To add momentary layer switching from the
       trigger, a behavior-aware mode would need to be added to the driver,
       or a physical button used for layer activation. */
    analog_stick_listener1: analog_stick_listener_1 {
        compatible = "zmk,analog-stick-listener";
        device = <&analog_stick1>;

        layer0 {
            layers = <0 1>;
            mode = <ANALOG_STICK_MODE_SWITCH>;
            left-keycode = <X>;
            right-keycode = <Z>;
            switch-activation-point = <40>;
            switch-hysteresis = <4>;
        };
    };
};

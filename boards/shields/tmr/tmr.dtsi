#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/analog-stick/modes.h>
#include <physical_layouts.dtsi>

&adc {
    status = "okay";

    #address-cells = <1>;
    #size-cells = <0>;
    channel@0 {
        reg = <0>;
        zephyr,input-positive = <NRF_SAADC_AIN0>;
        zephyr,gain = "ADC_GAIN_1_4";
        zephyr,reference = "ADC_REF_VDD_1_4";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };
    channel@1 {
        reg = <1>;
        zephyr,input-positive = <NRF_SAADC_AIN5>;
        zephyr,gain = "ADC_GAIN_1_4";
        zephyr,reference = "ADC_REF_VDD_1_4";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };
    channel@7 {
        reg = <7>;
        zephyr,input-positive = <NRF_SAADC_AIN7>;
        zephyr,gain = "ADC_GAIN_1_4";
        zephyr,reference = "ADC_REF_VDD_1_4";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };
};

/ {
    chosen {
        zmk,kscan = &kscan;
        zmk,physical-layout = &physical_layout0;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan>;
        transform = <&default_transform>;
        keys  /*                        w    h    x    y   rot  rx  ry */
            = <&key_physical_attrs    50  50    0    0    0   0   0>  /* 0: kscan dummy */
            , <&key_physical_attrs    50  50  125   25    0   0   0>  /* 1: stick0 up */
            , <&key_physical_attrs    50  50  125  125    0   0   0>  /* 2: stick0 down */
            , <&key_physical_attrs    50  50   75   75    0   0   0>  /* 3: stick0 left */
            , <&key_physical_attrs    50  50  175   75    0   0   0>  /* 4: stick0 right */
            , <&key_physical_attrs    50  50  275   50    0   0   0>  /* 5: stick1 left (X) */
            , <&key_physical_attrs    50  50  275  100    0   0   0>  /* 6: stick1 right (mo 1) */
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <7>;
        rows = <1>;
        map = <RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)>;
    };

    /* Minimal kscan — ZMK requires one even when all input comes from analog sticks.
       Using kscan-mock with no events so it never fires. */
    kscan: kscan0 {
        compatible = "zmk,kscan-mock";
        columns = <1>;
        rows = <1>;
        events = <0>;
    };

    /* Stick 0: PS5 dual-axis hall-effect joystick (X=AIN0, Y=AIN5) */
    analog_stick0: analog_stick_0 {
        compatible = "zmk,analog-stick";
        io-channels = <&adc 0>, <&adc 1>;
        x-min = <0>;
        x-center = <2035>;
        x-max = <4090>;
        y-min = <0>;
        y-center = <1965>;
        y-max = <4090>;
        deadzone-percent = <10>;
        wait-period-idle = <100>;
        wait-period-active = <8>;

        /* debug wait */
        /* wait-period-active = <500>; */

        /* Biquad IIR filter coefficients (b0, b1, b2, a0, a1, a2) — carried over from HE config */
        filter-coefficients = <0x3ca485df 0x3d2485df 0x3ca485df 0x3f800000 0xbfc7cf71 0x3f242f9d>;
    };

    /* Stick 1: Single-axis trigger on AIN7 (P0.31) */
    analog_stick1: analog_stick_1 {
        compatible = "zmk,analog-stick";
        io-channels = <&adc 7>;
        x-min = <0>;
        x-center = <2012>;
        x-max = <4090>;
        deadzone-percent = <10>;
        wait-period-idle = <100>;
        wait-period-active = <8>;

        /* debug wait */
        /* wait-period-active = <500>; */
        /* Biquad IIR filter coefficients (b0, b1, b2, a0, a1, a2) — carried over from HE config */

        filter-coefficients = <0x3ca485df 0x3d2485df 0x3ca485df 0x3f800000 0xbfc7cf71 0x3f242f9d>;
    };

    /* Listener for stick 0 — layer-aware mode switching.
       Directions reference keymap positions 1-4 (defined in transform above).
       Bindings at those positions are in the keymap and editable via Studio. */
    analog_stick_listener0: analog_stick_listener_0 {
        compatible = "zmk,analog-stick-listener";
        device = <&analog_stick0>;

        layer0 {
            layers = <0>;
            mode = <ANALOG_STICK_MODE_SWITCH>;
            up-position = <1>;
            down-position = <2>;
            left-position = <3>;
            right-position = <4>;
            switch-activation-point = <20>;
            switch-hysteresis = <2>;
        };
        layer1 {
            layers = <1>;
            mode = <ANALOG_STICK_MODE_MOUSE>;
            mouse-min-speed = <1>;
            mouse-max-speed = <15>;
        };
    };

    /* Listener for stick 1 — single-axis trigger.
       Directions reference keymap positions 5-6.
       Right direction is &mo 1 in the keymap — enables mouse layer! */
    analog_stick_listener1: analog_stick_listener_1 {
        compatible = "zmk,analog-stick-listener";
        device = <&analog_stick1>;

        layer0 {
            layers = <0 1>;
            mode = <ANALOG_STICK_MODE_SWITCH>;
            left-position = <5>;
            right-position = <6>;
            switch-activation-point = <20>;
            switch-hysteresis = <2>;
        };
    };
};

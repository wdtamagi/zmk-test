#include "tmr.dtsi"

// PS5 joystick has linear hall response — override Gateron polynomial with identity (y = x)
&kscan_adc {
    polyfit = <0x3f800000 0x00000000>; /* [1.0, 0.0] → y = x */
};

&kscan_adc_top {
    first {
        io-channels = <&adc 0>;
        // "left" half: center(~1877) to safe min(0) — 3.3V direct, no divider
        calibration-min = <0>;
        calibration-max = <1877>;
    };
};

&kscan_adc_bot {
    first {
        io-channels = <&adc 0>;
        // "right" half: center(~1877) to safe max(~3750) — 3.3V direct, no divider
        calibration-min = <1877>;
        calibration-max = <3750>;
    };
};

// Y axis (AIN5 / P0.29) — same calibration as X axis (same sensor type)
// May need calibration adjustment if Y axis center/range differs
&kscan_adc_up {
    first {
        io-channels = <&adc 1>;
        calibration-min = <0>;
        calibration-max = <1877>;
    };
};

&kscan_adc_down {
    first {
        io-channels = <&adc 1>;
        calibration-min = <1877>;
        calibration-max = <3750>;
    };
};

&central_listener{
    status = "okay";
};


&raw_sp {
    sample-div = <1>;
};

&he_transform {
    status="okay";
};

&he_keymap {
    status = "okay";
};

&gp_fw {
    working-area = <0 1877>;
    time-to-max-speed-ms = <0>;
    accumulation-time = <2>;
};
